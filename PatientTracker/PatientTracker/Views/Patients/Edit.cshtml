@model Patient

<h2>Edit Patient</h2>

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-2">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="Age"></label>
        <input asp-for="Age" class="form-control" />
    </div>

    <div class="form-group mb-2">
        <label asp-for="Symptoms"></label>
        <input asp-for="Symptoms" class="form-control" />
    </div>

    <div class="form-group mb-3">
        <label asp-for="BedNumber"></label>
        <input asp-for="BedNumber" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/Patients" class="btn btn-secondary">Cancel</a>
</form>
